# Copier vers .env et adapter si besoin (le fichier .env est ignoré par Git).
# Utilisé par Spring via les variables SPRING_DATASOURCE_* si tu les exportes avant ./mvnw.

SPRING_PROFILES_ACTIVE=local

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/gameboard
SPRING_DATASOURCE_USERNAME=gameboard
SPRING_DATASOURCE_PASSWORD=gameboard

# Quand Kafka sera branché côté app :
# SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
